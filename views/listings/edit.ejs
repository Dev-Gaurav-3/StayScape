<% layout("layouts/boiler.ejs") %>

    <div class="page-container">
        <a class="back-link" href="/listings/<%= listing._id %>">Back to listing</a>

        <div class="form-card">
            <h2 class="form-title">Edit your listing</h2>
            <p class="form-subtitle">Update the details below to keep your listing accurate.</p>
            <div class="form-divider"></div>

            <form method="post" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation">

                <div class="form-group">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control" type="text" id="title" value="<%= listing.title %>"
                        name="listing[title]" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a title.</div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="description">Description</label>
                    <textarea class="form-control" id="description" name="listing[description]"
                        required><%= listing.description %></textarea>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a description.</div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="image">Image URL</label>
                    <% if (listing.image && listing.image) { %>
                        <img src="<%= listing.image %>" alt="Current image"
                            style="width:100%; max-height:200px; object-fit:cover; border-radius:10px; margin-bottom:10px;">
                        <% } %>
                            <input class="form-control" type="url" id="image"
                                placeholder="https://example.com/photo.jpg" value="<%= listing.image %>"
                                name="listing[image]">
                            <div class="valid-feedback">Looks good!</div>
                            <div class="invalid-feedback">Please enter a valid image URL.</div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="price">Price per night (₹)</label>
                    <input class="form-control" type="number" id="price" name="listing[price]"
                        value="<%= listing.price %>" min="1" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a valid price.</div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="location">City / Location</label>
                        <input class="form-control" type="text" id="location" name="listing[location]"
                            value="<%= listing.location %>" required>
                        <div class="valid-feedback">Looks good!</div>
                        <div class="invalid-feedback">Please enter a location.</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="country">Country</label>
                        <input class="form-control" type="text" id="country" name="listing[country]"
                            value="<%= listing.country %>" required>
                        <div class="valid-feedback">Looks good!</div>
                        <div class="invalid-feedback">Please enter a country.</div>
                    </div>
                </div>

                <div class="form-divider"></div>
                <button type="submit" class="btn btn-primary btn-full">✏️ Save Changes</button>
            </form>
        </div>
    </div>