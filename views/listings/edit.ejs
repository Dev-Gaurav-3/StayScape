<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Listing — StayScape</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
    <a class="navbar-brand" href="/listings">Stay<span>Scape</span></a>

    <form class="navbar-search" action="/listings" method="get">
        <input
            type="text"
            name="search"
            placeholder="Search destinations, places…"
            value="<%= typeof search !== 'undefined' ? search : '' %>"
            autocomplete="off"
        >
        <button class="navbar-search-btn" type="submit">
            <i class="fa-solid fa-magnifying-glass" style="color: #ffffff"></i>
        </button>
    </form>

    <div style="display:flex; align-items:center; gap:12px;">
        <button class="theme-toggle" id="themeToggle" title="Toggle dark mode">🌙</button>
        <form action="/listings/new" method="get">
            <button class="btn btn-primary btn-sm">+ New Listing</button>
        </form>
    </div>
</nav>

    <!-- Main Content -->`

<div class="page-container">
    <a class="back-link" href="/listings/<%= listing._id %>">Back to listing</a>

    <div class="form-card">
        <h2 class="form-title">Edit your listing</h2>
        <p class="form-subtitle">Update the details below to keep your listing accurate.</p>
        <div class="form-divider"></div>

        <form method="post" action="/listings/<%= listing._id %>?_method=PUT"
              novalidate class="needs-validation">

            <div class="form-group">
                <label class="form-label" for="title">Title</label>
                <input
                    class="form-control"
                    type="text"
                    id="title"
                    value="<%= listing.title %>"
                    name="listing[title]"
                    required
                >
                <div class="valid-feedback">Looks good!</div>
                <div class="invalid-feedback">Please enter a title.</div>
            </div>

            <div class="form-group">
                <label class="form-label" for="description">Description</label>
                <textarea
                    class="form-control"
                    id="description"
                    name="listing[description]"
                    required
                ><%= listing.description %></textarea>
                <div class="valid-feedback">Looks good!</div>
                <div class="invalid-feedback">Please enter a description.</div>
            </div>

            <div class="form-group">
                <label class="form-label" for="image">Image URL</label>

                <!-- Show current image preview -->
                <% if (listing.image) { %>
                    <img
                        src="<%= listing.image%>"
                        alt="Current image"
                        style="width:100%; max-height:200px; object-fit:cover;
                               border-radius:10px; margin-bottom:10px;"
                    >
                <% } %>

                <input
                    class="form-control"
                    type="url"
                    id="image"
                    placeholder="https://example.com/photo.jpg"
                    value="<%= listing.image %>"
                    name="listing[image]"
                >
                <!-- Preserve filename so it isn't wiped -->
                <div class="valid-feedback">Looks good!</div>
                <div class="invalid-feedback">Please enter a valid image URL.</div>
            </div>

            <div class="form-group">
                <label class="form-label" for="price">Price per night (₹)</label>
                <input
                    class="form-control"
                    type="number"
                    id="price"
                    name="listing[price]"
                    value="<%= listing.price %>"
                    min="1"
                    required
                >
                <div class="valid-feedback">Looks good!</div>
                <div class="invalid-feedback">Please enter a valid price.</div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label" for="location">City / Location</label>
                    <input
                        class="form-control"
                        type="text"
                        id="location"
                        name="listing[location]"
                        value="<%= listing.location %>"
                        required
                    >
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a location.</div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="country">Country</label>
                    <input
                        class="form-control"
                        type="text"
                        id="country"
                        name="listing[country]"
                        value="<%= listing.country %>"
                        required
                    >
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a country.</div>
                </div>
            </div>

            <div class="form-divider"></div>
            <button type="submit" class="btn btn-primary btn-full">✏️ Save Changes</button>

        </form>
    </div>
</div>

    <!-- Footer -->
    <footer class="footer">
        &copy; 2026 <a href="/listings">StayScape</a>. All rights reserved.
    </footer>
    <%- include("../includes/darkscript.ejs")%>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://kit.fontawesome.com/04ea02bc57.js" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>
</body>
</html>
