<% layout("layouts/boiler.ejs") %>

    <div class="page-container">
        <a class="back-link" href="/listings">Back to listings</a>

        <div class="form-card">
            <h2 class="form-title">List your place</h2>
            <p class="form-subtitle">Share your space with travellers around the world.</p>
            <div class="form-divider"></div>

            <form action="/listings" method="post" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="form-group">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control" type="text" id="title" placeholder="e.g. Cozy mountain cabin"
                        name="listing[title]" required>
                    <div class="valid-feedback">Title looks good!</div>
                    <div class="invalid-feedback">Please enter a title.</div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="description">Description</label>
                    <textarea class="form-control" id="description"
                        placeholder="Tell guests what makes your place special…" name="listing[description]"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label" for="image">Image URL</label>
                    <input class="form-control" type="file" id="image" name="listing[image]">
                </div>

                <div class="form-group">
                    <label class="form-label" for="price">Price per night (₹)</label>
                    <input class="form-control" type="number" id="price" placeholder="e.g. 2500" name="listing[price]"
                        min="0" required>
                    <div class="invalid-feedback">Please enter a valid price.</div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="location">City / Location</label>
                        <input class="form-control" type="text" id="location" placeholder="e.g. Manali"
                            name="listing[location]" required>
                        <div class="invalid-feedback">Please enter a location.</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="country">Country</label>
                        <input class="form-control" type="text" id="country" placeholder="e.g. India"
                            name="listing[country]" required>
                        <div class="invalid-feedback">Please enter a country.</div>
                    </div>
                </div>

                <div class="form-divider"></div>
                <button type="submit" class="btn btn-primary btn-full">🏠 Add Listing</button>
            </form>
        </div>
    </div>