<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Listing — StayScape</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
    <a class="navbar-brand" href="/listings">Stay<span>Scape</span></a>

    <form class="navbar-search" action="/listings" method="get">
        <input
            type="text"
            name="search"
            placeholder="Search destinations, places…"
            value="<%= typeof search !== 'undefined' ? search : '' %>"
            autocomplete="off"
        >
        <button class="navbar-search-btn" type="submit">
            <i class="fa-solid fa-magnifying-glass" style="color: #ffffff"></i>

        </button>
    </form>

    <div style="display:flex; align-items:center; gap:12px;">
        <button class="theme-toggle" id="themeToggle" title="Toggle dark mode">🌙</button>
        <form action="/listings/new" method="get">
            <button class="btn btn-primary btn-sm">+ New Listing</button>
        </form>
    </div>
</nav>

    <!-- Main Content -->
    <div class="page-container">

        <a class="back-link" href="/listings">Back to listings</a>

        <div class="form-card">
            <h2 class="form-title">List your place</h2>
            <p class="form-subtitle">Share your space with travellers around the world.</p>

            <div class="form-divider"></div>

            <form action="/listings" method="post" novalidate class="needs-validation">

                <div class="form-group">
                    <label class="form-label" for="title">Title</label>
                    <input class="form-control"  type="text" id="title" placeholder="e.g. Cozy mountain cabin" name="listing[title]" required>
                    <div class="valid-feedback">Title looks good</div>
                    <div class="invalid-feedback">Title looks bad</div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="description">Description</label>
                    <textarea
                        class="form-control"
                        id="description"
                        placeholder="Tell guests what makes your place special…"
                        name="listing[description]"
                    ></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label" for="image">Image URL</label>
                    <input
                        class="form-control"
                        type="text"
                        id="image"
                        placeholder="https://example.com/photo.jpg"
                        name="listing[image]"
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="price">Price per night (₹)</label>
                    <input
                        class="form-control"
                        type="number"
                        id="price"
                        placeholder="e.g. 2500"
                        name="listing[price]"
                        min="0"
                        required
                    >
                    <div class="invalid-feedback">Please enter a valid price</div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="location">City / Location</label>
                        <input
                            class="form-control"
                            type="text"
                            id="location"
                            placeholder="e.g. Manali"
                            name="listing[location]"
                            required
                        >
                    <div class="invalid-feedback">Location should be valid</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="country">Country</label>
                        <input
                            class="form-control"
                            type="text"
                            id="country"
                            placeholder="e.g. India"
                            name="listing[country]"
                            required
                        >
                    <div class="invalid-feedback">Country should be valid</div>
                    </div>
                </div>

                <div class="form-divider"></div>

                <button type="submit" class="btn btn-primary btn-full">🏠 Add Listing</button>

            </form>
        </div>

    </div>

    <!-- Footer -->
    <footer class="footer">
        &copy; 2026 <a href="/listings">StayScape</a>. All rights reserved.
    </footer>
    <%- include("../includes/darkscript.ejs")%>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://kit.fontawesome.com/04ea02bc57.js" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>
</body>
</html>
