<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Listing — StayScape</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
    <a class="navbar-brand" href="/listings">Stay<span>Scape</span></a>

    <form class="navbar-search" action="/listings" method="get">
        <input
            type="text"
            name="search"
            placeholder="Search destinations, places…"
            value="<%= typeof search !== 'undefined' ? search : '' %>"
            autocomplete="off"
        >
        <button class="navbar-search-btn" type="submit">
            <i class="fa-solid fa-magnifying-glass" style="color: #ffffff"></i>
        </button>
    </form>

    <div style="display:flex; align-items:center; gap:12px;">
        <button class="theme-toggle" id="themeToggle" title="Toggle dark mode">🌙</button>
        <form action="/listings/new" method="get">
            <button class="btn btn-primary btn-sm">+ New Listing</button>
        </form>
    </div>
</nav>

    <div class="page-container">
        <div class="error-box">
            <div class="error-icon">⚠️</div>
            <h2 class="error-title">Something went wrong</h2>
            <p class="error-message"><%= msg %></p>
            <a href="/listings" class="btn btn-primary">Go back to listings</a>
        </div>
    </div>
    <!-- Footer -->
    <footer class="footer">
        &copy; 2026 <a href="/listings">StayScape</a>. All rights reserved.
    </footer>
    <%- include("../includes/darkscript.ejs")%>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://kit.fontawesome.com/04ea02bc57.js" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>
</body>
</html>
