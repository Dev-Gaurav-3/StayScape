<% layout("layouts/boiler.ejs") %>

    <div class="page-container">
        <div class="listings-header">
            <h1 class="page-heading">Explore <span>Places</span></h1>
            <span class="badge">All Listings</span>
        </div>

        <% if (allListings.length===0) { %>
            <div class="empty-state">
                <div class="empty-icon">🔍</div>
                <h3>No listings found</h3>
                <p>No results for "<strong>
                        <%= search %>
                    </strong>". Try a different search.</p>
                <a href="/listings" class="btn btn-outline">Clear Search</a>
            </div>
            <% } else { %>
                <% if (search) { %>
                    <p class="search-result-info">
                        Showing <strong>
                            <%= allListings.length %>
                        </strong> result<%= allListings.length> 1 ? 's' : '' %>
                            for "<strong>
                                <%= search %>
                            </strong>"
                            &nbsp;<a href="/listings" class="clear-search">✕ Clear</a>
                    </p>
                    <% } %>
                        <div class="listings-grid">
                            <% for(let listing of allListings){ %>
                                <a class="listing-card" href="/listings/<%= listing._id %>">
                                    <div class="listing-card-thumb">
                                        <% if (listing.image) { %>
                                            <img src="<%= listing.image %>" alt="<%= listing.title %>">
                                            <% } else { %>
                                                <img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470"
                                                    alt="default">
                                                <% } %>
                                    </div>
                                    <div class="listing-card-body">
                                        <div class="listing-card-title">
                                            <%= listing.title %>
                                        </div>
                                        <div class="listing-card-location">📍 <%= listing.location %>, <%=
                                                    listing.country %>
                                        </div>
                                    </div>
                                </a>
                                <% } %>
                        </div>
                        <% } %>
    </div>