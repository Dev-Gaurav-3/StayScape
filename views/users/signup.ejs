<% layout("./layouts/boiler.ejs") %>

    <div class="page-container">
        <div class="form-card">
            <h2 class="form-title">Create Account</h2>
            <p class="form-subtitle">Join StayScape today.</p>
            <div class="form-divider"></div>

            <form action="/signup" method="post" novalidate class="needs-validation">

                <div class="form-group">
                    <label class="form-label" for="username">Username</label>
                    <input class="form-control" type="text" id="username" placeholder="e.g. john_doe" name="username"
                        required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a username.</div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="email">Email</label>
                    <input class="form-control" type="email" id="email" placeholder="e.g. john@example.com" name="email"
                        required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a valid email.</div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <input class="form-control" type="password" id="password" placeholder="Min. 6 characters"
                        name="password" minlength="6" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Password must be at least 6 characters.</div>
                </div>

                <div class="form-divider"></div>

                <button type="submit" class="btn btn-primary btn-full">
                    Sign Up
                </button>

                <p class="auth-switch">
                    Already have an account? <a href="/login">Log in</a>
                </p>

            </form>
        </div>
    </div>